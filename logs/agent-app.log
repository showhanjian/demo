cription":"Label the subtask as done by given index and outcome","parameters":{"type":"object","properties":{"subtask_idx":{"type":"integer","description":"The index of the sub-task to be marked as done, starting from 0"},"subtask_outcome":{"type":"string","description":"The specific outcome of the sub-task, should exactly match the expected outcome in the sub-task description. SHOULDN'T be what you did or general description, e.g. \"I have searched xxx\", \"I have written the code for xxx\", etc. It SHOULD be the specific data, information, or path to the file, e.g. \"There are 5 articles about xxx, they are\\n- xxx\\n- xxx\\n...\""}},"required":["subtask_idx","subtask_outcome"]}}},{"type":"function","function":{"name":"Tool_dis_Report","description":"获取报表内容，返回给 Agent 推送到前端展示","parameters":{"type":"object","properties":{}}}},{"type":"function","function":{"name":"load_skill_through_path","description":"Load and activate a skill resource by its ID and resource path.\n\n**Functionality:**\n1. Activates the specified skill (making its tools available)\n2. Returns the requested resource content\n usage instructions)\n- 'SKILL.md': The skill's markdown documentation (name, description,- Other paths: Additional resources like scripts, configs, templates, or data files","parameters":{"type":"object","required":["skillId","path"],"properties":{"skillId":{"type":"string","description":"The unique identifier of the skill.","enum":["plando_report_wj_custom"]},"path":{"description":"The path to the resource file within the skill (e.g., 'SKILL.md, references/references.md')","type":"string"}}}}},{"type":"function","function":{"name":"update_plan_info","description":"Update the current plan's name, description, or expected outcome. Pass null or empty string to keep a field unchanged.","parameters":{"type":"object","properties":{"name":{"type":"string","description":"The new plan name (optional, pass null or empty to keep unchanged)"},"description":{"type":"string","description":"The new plan description (optional, pass null or empty to keep unchanged)"},"expected_outcome":{"type":"string","description":"The new expected outcome (optional, pass null or empty to keep unchanged)"}},"required":["name","description","expected_outcome"]}}},{"type":"function","function":{"name":"Tool_get_Report","description":"检查 full_report.csv 是否存在，返回存在性结果","parameters":{"type":"object","properties":{}}}},{"type":"function","function":{"name":"get_subtask_count","description":"Get the number of subtasks in the current plan","parameters":{"type":"object","properties":{}}}}],"user":"user01"}
