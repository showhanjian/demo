andoned"}},"required":["state","outcome"]}}},{"type":"function","function":{"name":"Tool_chk_Report","description":"核对报表中明细金额列的合计是否等于最后一行合计金额","parameters":{"type":"object","properties":{}}}},{"type":"function","function":{"name":"update_subtask_state","description":"Update the state of a subtask by given index and state","parameters":{"type":"object","properties":{"subtask_idx":{"type":"integer","description":"The index of the subtask to be updated, starting from 0"},"state":{"type":"string","description":"The new state: todo/in_progress/abandoned"}},"required":["subtask_idx","state"]}}},{"type":"function","function":{"name":"view_subtasks","description":"View the details of the sub-tasks by given indexes","parameters":{"type":"object","properties":{"subtask_idx":{"type":"array","items":{"type":"integer"},"description":"The indexes of the sub-tasks to be viewed, starting from 0"}},"required":["subtask_idx"]}}},{"type":"function","function":{"name":"view_historical_plans","description":"View the historical plans","parameters":{"type":"object","properties":{}}}},{"type":"function","function":{"name":"recover_historical_plan","description":"Recover a historical plan by given plan ID","parameters":{"type":"object","properties":{"plan_id":{"type":"string","description":"The ID of the historical plan to be recovered"}},"required":["plan_id"]}}},{"type":"function","function":{"name":"revise_current_plan","description":"Revise the current plan by adding, revising or deleting a sub-task","parameters":{"type":"object","properties":{"subtask_idx":{"type":"integer","description":"The index of the sub-task to be revised, starting from 0"},"action":{"type":"string","description":"The action to be performed: add/revise/delete"},"subtask":{"type":"object","description":"The sub-task to be added or revised (required for add/revise)"}},"required":["subtask_idx","action","subtask"]}}},{"type":"function","function":{"name":"create_plan","description":"Create a plan by given name and sub-tasks","parameters":{"type":"object","properties":{"subtasks":{"type":"array","items":{"type":"object"},"description":"A list of sequential sub-tasks. Each subtask must be an object with: 'name' (string, required), 'description' (string), 'expected_outcome' (string). Example: [{\"name\": \"Calculate area\", \"description\": \"Multiply length by width\", \"expected_outcome\": \"Area value\"}]"},"name":{"type":"string","description":"The plan name, should be concise, descriptive and not exceed 10 words"},"description":{"type":"string","description":"The plan description, including the constraints, target and outcome to be achieved. The description should be clear, specific and concise, and all the constraints, target and outcome should be specific and measurable"},"expected_outcome":{"type":"string","description":"The expected outcome of the plan, which should be specific, concrete and measurable"}},"required":["name","description","expected_outcome","subtasks"]}}},{"type":"function","function":{"name":"finish_subtask","description":"Label the subtask as done by given index and outcome","parameters":{"type":"object","properties":{"subtask_idx":{"type":"integer","description":"The index of the sub-task to be marked as done, starting from 0"},"subtask_outcome":{"type":"string","description":"The specific outcome of the sub-task, should exactly match the expected outcome in the sub-task description. SHOULDN'T be what you did or general description, e.g. \"I have searched xxx\", \"I have written the code for xxx\", etc. It SHOULD be the specific data, information, or path to the file, e.g. \"There are 5 articles about xxx, they are\\n- xxx\\n- xxx\\n...\""}},"required":["subtask_idx","subtask_outcome"]}}},{"type":"function","function":{"name":"Tool_dis_Report","description":"获取报表内容，返回给 Agent 推送到前端展示","parameters":{"type":"object","properties":{}}}},{"type":"function","function":{"name":"load_skill_through_path","description":"Load and activate a skill resource by its I